<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Student Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F4F7FE;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #fff;
            padding: 50px 40px;
            border-radius: 24px;
            box-shadow: 0 20px 45px rgba(43, 54, 116, 0.08);
            width: 100%;
            max-width: 420px;
        }
        .logo-box {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #FF9C00, #FFC048);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 1.4rem;
            margin: 0 auto 20px;
        }
        h4 { color: #2B3674; font-weight: 700; }
        .subtext { color: #A3AED0; font-size: 0.9rem; }
        .form-control {
            background: #F8FAFC;
            border: 1px solid #E2E8F0;
            border-radius: 12px;
            padding: 12px 16px;
        }
        .form-control:focus {
            border-color: #6366F1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
            background: #fff;
        }
        .btn-signin {
            background: #6366F1;
            color: #fff;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            width: 100%;
            border: none;
        }
        .btn-signin:hover { background: #4F46E5; color: #fff; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-box">S</div>
        <div class="text-center mb-4">
            <h4>Welcome Back</h4>
            <p class="subtext mb-0">Student Management System</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger py-2 small"><%= error %></div>
        <% } %>

        <form method="POST" action="/login">
            <div class="mb-3">
                <label class="form-label small fw-semibold" style="color:#2B3674;">Email Address</label>
                <input type="text" name="email" class="form-control" placeholder="Enter your email" required>
            </div>
            <div class="mb-4">
                <label class="form-label small fw-semibold" style="color:#2B3674;">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="btn btn-signin">Sign In</button>
        </form>
    </div>
</body>
</html>
